# Copy to .env and fill in. .env is git-ignored.
# Only needed if you want to refresh holder data; the dashboard works without it
# (falls back to manually-seeded top-10 concentration values).

# Alchemy API key — free tier at https://alchemy.com (300M compute units/month)
# Used by scripts/fetch_holders_alchemy.py to walk ERC-20 Transfer events and
# compute live top-10 wallet concentration per L2 token.
ALCHEMY_API_KEY=
