# Copy to .env and fill in. .env is git-ignored.

# Dashboard password (required on Vercel; middleware fails closed without it)
# Set in Vercel: Project Settings → Environment Variables → DASHBOARD_PASSWORD
# Optional: DASHBOARD_USERNAME (defaults to "adi")
DASHBOARD_PASSWORD=
DASHBOARD_USERNAME=

# The remaining vars below are only needed if you want to refresh holder data;
# the dashboard works without them (falls back to previously-committed values).

# Moralis API key — free tier at https://moralis.io (40K compute units/day).
# Used by scripts/fetch_holders_moralis.py — primary source for live top-10
# holder concentration. One indexed REST call per token (no event walking).
# Covers 14/17 L2 governance tokens; Scroll, Blast, BOB keep manual seeds
# since Moralis does not index those chains.
MORALIS_API_KEY=

# Alchemy API key — free tier at https://alchemy.com (300M compute units/month).
# Optional fallback. scripts/fetch_holders_alchemy.py walks ERC-20 Transfer
# events directly. Slower than Moralis and hits caps on high-volume tokens;
# kept for chains Moralis doesn't cover or for cross-validation.
ALCHEMY_API_KEY=
